# ─────────────────────────────────────────────────────────────────────────
# IELTSAce — environment template. Copy to .env.local and fill in real values.
# .env.local is gitignored; never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────

# ── Core (required to boot) ──
# Postgres connection string.
DATABASE_URL=
# "true" to require TLS to the database (managed/hosted Postgres).
DATABASE_SSL=false
# Absolute base URL of the app — used for canonical + OpenGraph URLs.
# Local dev: http://localhost:3000   ·   Production: https://your-domain.com
APP_URL=http://localhost:3000

# ── AWS S3 (required for Speaking — stores uploaded audio) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
# Optional key prefix inside the bucket (e.g. "audio/").
S3_FOLDER_PREFIX=

# ── SpeechSuper (required for Speaking AI band scoring) ──
SPEECHSUPER_API_KEY=
SPEECHSUPER_SECRET_KEY=
SPEECHSUPER_BASE_URL=

# ── Writing AI band scoring (Google Gemini — WIRED) ──
# Grades Writing Task 1/2 on the four IELTS criteria. Without it, Writing
# submissions save but stay unscored (band = null).
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash

# ── Email / transactional (PLANNED: verification, password reset, receipts) ──
# RESEND_API_KEY=
# EMAIL_FROM=

# ── Rate limiting (all optional — these are the defaults) ──
# General per-user action limits.
RATE_LIMIT_GENERAL_PER_MINUTE=60
RATE_LIMIT_GENERAL_PER_DAY=6000
# AI (Writing/Speaking scoring) — expensive, so tighter.
RATE_LIMIT_AI_PER_DAY=100
RATE_LIMIT_AI_PER_ACCOUNT=10000
RATE_LIMIT_AI_ACCOUNT_WINDOW_DAYS=365
# Auto-deactivate an account after this many throttling violations within the window.
RATE_LIMIT_VIOLATIONS_BEFORE_DEACTIVATE=3
RATE_LIMIT_VIOLATION_WINDOW_DAYS=30

# ── Payments / Razorpay (PLANNED: subscriptions + webhooks) ──
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
