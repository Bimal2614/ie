# ---------------------------------------------------------------------------
# IELTSAce — Next.js 16 (Turbopack) · TypeScript · Drizzle/Postgres
# See https://git-scm.com/docs/gitignore
# ---------------------------------------------------------------------------

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store/

# Next.js build output + caches (Turbopack is the default builder in 16)
/.next/
/out/
/build
/dist
.turbo/
*.tsbuildinfo
next-env.d.ts

# Test / coverage
/coverage
/playwright-report/
/test-results/
.nyc_output/

# ---------------------------------------------------------------------------
# Secrets & environment
# Ignore every .env*, but keep committed templates so a clone can boot.
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
*.pem
*.key

# ---------------------------------------------------------------------------
# Database (Drizzle)
# Migrations in src/db/migrations ARE committed — they are source of truth.
# Only local dumps / scratch artifacts are ignored.
# ---------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
/tmp/
/.drizzle/
*.dump
*.sql.bak

# Logs & debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# Deploy
.vercel
.netlify/

# Editors / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# OS cruft
.DS_Store
Thumbs.db
Desktop.ini

# Claude Code — keep shared config, ignore per-user local overrides
.claude/settings.local.json

# Scratch / temp analysis scripts (kept out of history by convention)
*.tmp
.scratch/
